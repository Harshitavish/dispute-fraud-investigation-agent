# Copy to .env and fill in what you need. Every value has a working default,
# so the system runs with an empty .env -- just without Claude-written prose.

# --- LLM -------------------------------------------------------------------
# Without a key the agents fall back to deterministic rule-based reasoning and
# templated notifications. The pipeline still completes end to end.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
LLM_EFFORT=high

# --- Database --------------------------------------------------------------
# Defaults to SQLite at ./data/razorpay_agentic.db
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/disputes

# --- Email -----------------------------------------------------------------
# SMTP is OFF by default. Messages are written to ./outbox as .eml files so you
# can read exactly what the agent would have sent. Only turn this on when you
# actually want mail leaving the machine.
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=disputes@razorpay-demo.local

# --- Risk policy -----------------------------------------------------------
AUTO_REFUND_BELOW=30
AUTO_REJECT_ABOVE=70
# Amount in paise above which a human must approve, regardless of risk score.
MANUAL_REVIEW_AMOUNT_PAISE=5000000
